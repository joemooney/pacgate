        .mld_type     (mld_type),
        .mld_valid    (mld_valid),
        .fields_valid (fields_valid)
    );

    // Dynamic flow table (replaces per-rule static matchers)
    flow_table #(
        .NUM_ENTRIES ({{ num_entries }}),
        .IDX_BITS    ({{ idx_bits }})
    ) u_flow_table (
        .clk            (clk),
        .rst_n          (rst_n),
        .dst_mac        (dst_mac),
        .src_mac        (src_mac),
        .ethertype      (ethertype),
        .vlan_id        (vlan_id),
        .src_ip         (src_ip),
