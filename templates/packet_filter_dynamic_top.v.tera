        .dst_ip       (dst_ip),
        .ip_protocol  (ip_protocol),
        .l3_valid     (l3_valid),
        .src_ipv6     (src_ipv6),
        .dst_ipv6     (dst_ipv6),
        .ipv6_next_header (ipv6_next_header),
        .ipv6_valid   (ipv6_valid),
        .src_port     (src_port),
        .dst_port     (dst_port),
        .l4_valid     (l4_valid),
        .vxlan_vni    (vxlan_vni),
        .vxlan_valid  (vxlan_valid),
        .gtp_teid     (gtp_teid),
