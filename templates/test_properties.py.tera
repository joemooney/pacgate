import os
import sys

# Add project root to path for verification framework
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))

from verification.scoreboard import Rule
from verification.properties import run_property_tests

# Try importing hypothesis for enhanced property testing
try:
    from hypothesis import given, settings
    from verification.properties import (
        ethernet_frames, l3l4_ethernet_frames, HYPOTHESIS_AVAILABLE,
        check_determinism, check_conservation, check_independence,
        check_priority_correctness, check_default_action,
        check_l3l4_determinism,
        check_cidr_boundary, check_port_range_boundary, check_ipv6_cidr_match,
        check_tunnel_determinism, check_protocol_determinism,
        gtp_u_frames, mpls_frames, igmp_frames, mld_frames,
        gre_frames, oam_frames, nsh_frames, arp_frames,
        icmp_frames, icmpv6_frames, qinq_frames, tcp_flags_frames,
    )
    from verification.scoreboard import PacketFilterScoreboard
except ImportError:
    HYPOTHESIS_AVAILABLE = False


# ── Rule Set Definition ─────────────────────────────────────────

RULES = [
{% for rule in scoreboard_rules %}
    Rule(
        name="{{ rule.name }}",
        priority={{ rule.priority }},
        action="{{ rule.action }}",
{% if rule.ethertype is defined %}
        ethertype={{ rule.ethertype }},
{% endif %}
{% if rule.dst_mac is defined %}
        dst_mac="{{ rule.dst_mac }}",
{% endif %}
{% if rule.src_mac is defined %}
        src_mac="{{ rule.src_mac }}",
{% endif %}
{% if rule.vlan_id is defined %}
        vlan_id={{ rule.vlan_id }},
{% endif %}
{% if rule.vlan_pcp is defined %}
        vlan_pcp={{ rule.vlan_pcp }},
{% endif %}
{% if rule.src_ip is defined %}
        src_ip="{{ rule.src_ip }}",
{% endif %}
{% if rule.dst_ip is defined %}
        dst_ip="{{ rule.dst_ip }}",
{% endif %}
{% if rule.ip_protocol is defined %}
        ip_protocol={{ rule.ip_protocol }},
{% endif %}
{% if rule.src_port is defined %}
        src_port={{ rule.src_port }},
{% endif %}
{% if rule.dst_port is defined %}
        dst_port={{ rule.dst_port }},
{% endif %}
{% if rule.src_port_range is defined %}
        src_port_range=({{ rule.src_port_range }}),
{% endif %}
{% if rule.dst_port_range is defined %}
        dst_port_range=({{ rule.dst_port_range }}),
{% endif %}
{% if rule.vxlan_vni is defined %}
        vxlan_vni={{ rule.vxlan_vni }},
{% endif %}
{% if rule.src_ipv6 is defined %}
        src_ipv6="{{ rule.src_ipv6 }}",
{% endif %}
{% if rule.dst_ipv6 is defined %}
        dst_ipv6="{{ rule.dst_ipv6 }}",
{% endif %}
{% if rule.ipv6_next_header is defined %}
        ipv6_next_header={{ rule.ipv6_next_header }},
{% endif %}
{% if rule.gtp_teid is defined %}
        gtp_teid={{ rule.gtp_teid }},
{% endif %}
{% if rule.mpls_label is defined %}
        mpls_label={{ rule.mpls_label }},
{% endif %}
{% if rule.mpls_tc is defined %}
        mpls_tc={{ rule.mpls_tc }},
{% endif %}
{% if rule.mpls_bos is defined %}
        mpls_bos={{ rule.mpls_bos }},
{% endif %}
{% if rule.igmp_type is defined %}
        igmp_type={{ rule.igmp_type }},
{% endif %}
{% if rule.mld_type is defined %}
        mld_type={{ rule.mld_type }},
{% endif %}
    ),
{% endfor %}
]

DEFAULT_ACTION = "{{ default_action }}"


# ── Random Property Tests ───────────────────────────────────────

def test_property_random_suite():
    """Run property-based tests with 200 random frames."""
    results = run_property_tests(RULES, default_action=DEFAULT_ACTION, num_samples=200)
    print(results.report())
    assert results.all_passed, f"{len(results.failures)} property tests failed"


# ── Hypothesis-Based Property Tests (if available) ──────────────

if HYPOTHESIS_AVAILABLE:
    scoreboard = PacketFilterScoreboard(RULES, default_action=DEFAULT_ACTION)

    @given(frame=ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_determinism(frame):
        """Same frame always produces same decision."""
        assert check_determinism(scoreboard, frame)

    @given(frame=ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_conservation(frame):
        """Every frame gets exactly one decision."""
        assert check_conservation(scoreboard, frame)

    @given(frame=ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_independence(frame):
        """Payload content doesn't affect filter decision."""
        assert check_independence(scoreboard, frame)

    @given(frame=ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_priority(frame):
        """Highest-priority matching rule always wins."""
        assert check_priority_correctness(scoreboard, RULES, frame)

    @given(frame=ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_default(frame):
        """Non-matching frames get default action."""
        assert check_default_action(scoreboard, RULES, frame, DEFAULT_ACTION)

    @given(data=l3l4_ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_l3l4_determinism(data):
        """L3/L4 matching is deterministic with extracted fields."""
        frame, extracted = data
        assert check_l3l4_determinism(scoreboard, frame, extracted)

    @given(data=l3l4_ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_cidr_boundary(data):
        """CIDR boundary matching is consistent."""
        frame, extracted = data
        assert check_cidr_boundary(scoreboard, RULES, frame, extracted)

    @given(data=l3l4_ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_port_range_boundary(data):
        """Port range boundary matching is consistent."""
        frame, extracted = data
        assert check_port_range_boundary(scoreboard, RULES, frame, extracted)

    @given(data=l3l4_ethernet_frames())
    @settings(max_examples=100, deadline=None)
    def test_hypothesis_ipv6_cidr_match(data):
        """IPv6 CIDR matching is deterministic."""
        frame, extracted = data
        assert check_ipv6_cidr_match(scoreboard, frame, extracted)

