#!/bin/bash
# MCY mutation test runner script
# Generated by pacgate — do not edit
#
# This script copies the mutated Verilog into the RTL directory,
# runs the cocotb simulation, and returns the exit code.
# MCY calls this once per mutation point.

set -e

# Paths (relative to MCY working directory)
TB_DIR="{{ tb_dir }}"
RTL_DIR="{{ rtl_dir }}"

# If MCY provides a mutated source file, copy it into the RTL dir
if [ -n "$1" ]; then
    cp "$1" "${RTL_DIR}/"
fi

# Run cocotb simulation
cd "${TB_DIR}"
make -s 2>/dev/null
exit $?
