"""
test_axi_packet_filter.py — cocotb test harness for AXI-Stream wrapper
Generated by pacgate — do not edit

Tests:
  - Basic frame passthrough (allowed frame appears on output)
  - Frame drop (blocked frame does not appear on output)
  - Backpressure handling (tready deassertion)
  - Burst traffic (multiple back-to-back frames)
  - FIFO overflow behavior
"""

import os
import sys
import random

import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, ClockCycles, Timer

# Add project root to path for verification framework
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))

from verification.packet import (
    EthernetFrame, PacketFactory, VlanTag, mac_to_bytes
)


# ── Helpers ─────────────────────────────────────────────────────

async def setup(dut):
    """Common test setup: clock + reset."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())

    # Reset
    dut.rst_n.value = 0
    dut.s_axis_tdata.value = 0
    dut.s_axis_tvalid.value = 0
    dut.s_axis_tlast.value = 0
    dut.m_axis_tready.value = 1
    await ClockCycles(dut.clk, 5)
    dut.rst_n.value = 1
    await ClockCycles(dut.clk, 5)


async def send_frame_axi(dut, frame_bytes):
    """Send a frame via AXI-Stream slave interface."""
    for i, byte in enumerate(frame_bytes):
        dut.s_axis_tdata.value = byte
        dut.s_axis_tvalid.value = 1
        dut.s_axis_tlast.value = 1 if (i == len(frame_bytes) - 1) else 0
        await RisingEdge(dut.clk)
        # Wait for tready
        while not dut.s_axis_tready.value:
            await RisingEdge(dut.clk)
    dut.s_axis_tvalid.value = 0
    dut.s_axis_tlast.value = 0


async def collect_output_frame(dut, timeout_cycles=500):
    """Collect output frame from AXI-Stream master interface."""
    frame_bytes = []
    cycle = 0
    got_data = False

    while cycle < timeout_cycles:
        await RisingEdge(dut.clk)
        cycle += 1

        if dut.m_axis_tvalid.value and dut.m_axis_tready.value:
            frame_bytes.append(int(dut.m_axis_tdata.value))
            got_data = True
            if dut.m_axis_tlast.value:
                return frame_bytes

    return frame_bytes if got_data else None


# ── Tests ───────────────────────────────────────────────────────

@cocotb.test()
async def test_axi_passthrough(dut):
    """A frame matching a PASS rule should appear on the output."""
    await setup(dut)

    # Build an ARP frame (matches allow_arp rule if present)
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("de:ad:be:ef:00:01"),
        src_mac=mac_to_bytes("02:00:00:00:00:01"),
        ethertype=0x0806,
        payload=bytes(46),
    )
    frame_bytes = frame.to_bytes()

    await send_frame_axi(dut, frame_bytes)

    # Wait for decision
    for _ in range(50):
        await RisingEdge(dut.clk)
        if dut.decision_valid.value:
            break

    if dut.decision_pass.value:
        # Frame should appear on output
        output = await collect_output_frame(dut)
        assert output is not None, "Expected output frame but got none"
        dut._log.info("AXI passthrough: received %d bytes on output", len(output))
    else:
        dut._log.info("AXI passthrough: frame dropped by filter (rule-dependent)")


@cocotb.test()
async def test_axi_frame_drop(dut):
    """A frame hitting DROP should not appear on output."""
    await setup(dut)

    # Use a reserved EtherType unlikely to match any rule
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("00:00:00:00:00:99"),
        src_mac=mac_to_bytes("00:00:00:00:00:88"),
        ethertype=0x88B5,
        payload=bytes(46),
    )
    frame_bytes = frame.to_bytes()

    await send_frame_axi(dut, frame_bytes)

    # Wait for decision
    for _ in range(50):
        await RisingEdge(dut.clk)
        if dut.decision_valid.value:
            break

    if not dut.decision_pass.value:
        # Frame should NOT appear on output — wait and verify
        output = await collect_output_frame(dut, timeout_cycles=100)
        assert output is None or len(output) == 0, \
            f"Expected no output for dropped frame, got {len(output) if output else 0} bytes"
        dut._log.info("AXI frame drop: correctly suppressed output")
    else:
        dut._log.info("AXI frame drop: frame passed (default action is pass)")


@cocotb.test()
async def test_axi_backpressure(dut):
    """Output backpressure (tready=0) should pause frame output."""
    await setup(dut)

    frame = EthernetFrame(
        dst_mac=mac_to_bytes("de:ad:be:ef:00:01"),
        src_mac=mac_to_bytes("02:00:00:00:00:01"),
        ethertype=0x0806,
        payload=bytes(46),
    )
    frame_bytes = frame.to_bytes()

    await send_frame_axi(dut, frame_bytes)

    # Wait for decision
    for _ in range(50):
        await RisingEdge(dut.clk)
        if dut.decision_valid.value:
            break

    if dut.decision_pass.value:
        # Deassert tready to apply backpressure
        dut.m_axis_tready.value = 0
        await ClockCycles(dut.clk, 10)

        # Re-assert tready
        dut.m_axis_tready.value = 1
        output = await collect_output_frame(dut)
        assert output is not None, "Frame should still be delivered after backpressure release"
        dut._log.info("AXI backpressure: frame delivered after tready re-asserted (%d bytes)", len(output))
    else:
        dut._log.info("AXI backpressure: skipped (frame dropped by filter)")


@cocotb.test()
async def test_axi_burst_traffic(dut):
    """Send multiple frames back-to-back via AXI-Stream."""
    await setup(dut)

    frames = [
        EthernetFrame(
            dst_mac=mac_to_bytes("de:ad:be:ef:00:01"),
            src_mac=mac_to_bytes("02:00:00:00:00:01"),
            ethertype=0x0806,
            payload=bytes(46),
        ),
        EthernetFrame(
            dst_mac=mac_to_bytes("de:ad:be:ef:00:02"),
            src_mac=mac_to_bytes("02:00:00:00:00:02"),
            ethertype=0x0800,
            payload=bytes(46),
        ),
        EthernetFrame(
            dst_mac=mac_to_bytes("de:ad:be:ef:00:03"),
            src_mac=mac_to_bytes("02:00:00:00:00:03"),
            ethertype=0x0806,
            payload=bytes(46),
        ),
    ]

    for i, frame in enumerate(frames):
        await send_frame_axi(dut, frame.to_bytes())
        # Small gap between frames
        await ClockCycles(dut.clk, 5)

    # Collect whatever comes out
    received = 0
    for _ in range(3):
        output = await collect_output_frame(dut, timeout_cycles=200)
        if output and len(output) > 0:
            received += 1

    dut._log.info("AXI burst: sent 3 frames, received %d on output", received)


@cocotb.test()
async def test_axi_reset_recovery(dut):
    """Reset during AXI transfer, then verify normal operation resumes."""
    await setup(dut)

    # Start sending a frame
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("de:ad:be:ef:00:01"),
        src_mac=mac_to_bytes("02:00:00:00:00:01"),
        ethertype=0x0806,
        payload=bytes(46),
    )
    frame_bytes = frame.to_bytes()

    # Send partial frame
    for i in range(8):
        dut.s_axis_tdata.value = frame_bytes[i]
        dut.s_axis_tvalid.value = 1
        dut.s_axis_tlast.value = 0
        dut.s_axis_tdata.value = frame_bytes[i] if i < len(frame_bytes) else 0
        await RisingEdge(dut.clk)

    dut.s_axis_tvalid.value = 0

    # Reset
    dut.rst_n.value = 0
    await ClockCycles(dut.clk, 5)
    dut.rst_n.value = 1
    await ClockCycles(dut.clk, 5)

    # Send a complete frame after reset
    await send_frame_axi(dut, frame_bytes)

    # Wait for decision
    for _ in range(50):
        await RisingEdge(dut.clk)
        if dut.decision_valid.value:
            break

    dut._log.info("AXI reset recovery: decision_valid=%d, decision_pass=%d",
                  int(dut.decision_valid.value), int(dut.decision_pass.value))
