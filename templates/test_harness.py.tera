{% for tc in test_cases %}

@cocotb.test()
async def {{ tc.name }}(dut):
    """{{ tc.description }}"""
    driver, monitor = await setup(dut)
{% if tc.has_vlan == "true" %}
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("{{ tc.dst_mac }}"),
        src_mac=mac_to_bytes("{{ tc.src_mac }}"),
        ethertype={{ tc.ethertype }},
        vlan_tag=VlanTag(vid={{ tc.vlan_id }}, pcp={{ tc.vlan_pcp }}),
        payload=bytes(46),
    )
{% else %}
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("{{ tc.dst_mac }}"),
        src_mac=mac_to_bytes("{{ tc.src_mac }}"),
        ethertype={{ tc.ethertype }},
        payload=bytes(46),
    )
{% endif %}
    await driver.send(frame)
    result = await monitor.wait_for_decision()
    expected = {% if tc.expect_pass == "true" %}1{% else %}0{% endif %}
    assert result == expected, \
        f"{{ tc.name }}: expected decision_pass={expected}, got {result}"
