import os
import sys
import random
import struct

import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, ClockCycles

# Add project root to path for verification framework
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))

from verification.packet import (
    EthernetFrame, PacketFactory, VlanTag, mac_to_bytes,
    Ipv4Header, Ipv6Header, ipv4_addr_to_bytes, ipv6_addr_to_bytes,
)
from verification.scoreboard import PacketFilterScoreboard, Rule
from verification.coverage import FilterCoverage
from verification.driver import PacketDriver, DecisionMonitor


# ── Scoreboard Setup ──────────────────────────────────────────────

def build_scoreboard():
    """Build the reference model scoreboard from the compiled rule set."""
    rules = [
{% for rule in scoreboard_rules %}
        Rule(
            name="{{ rule.name }}",
            priority={{ rule.priority }},
            action="{{ rule.action }}",
{% if rule.ethertype is defined %}
            ethertype={{ rule.ethertype }},
{% endif %}
{% if rule.dst_mac is defined %}
            dst_mac="{{ rule.dst_mac }}",
{% endif %}
{% if rule.src_mac is defined %}
            src_mac="{{ rule.src_mac }}",
{% endif %}
{% if rule.vlan_id is defined %}
            vlan_id={{ rule.vlan_id }},
{% endif %}
{% if rule.vlan_pcp is defined %}
            vlan_pcp={{ rule.vlan_pcp }},
{% endif %}
{% if rule.src_ip is defined %}
            src_ip="{{ rule.src_ip }}",
{% endif %}
{% if rule.dst_ip is defined %}
            dst_ip="{{ rule.dst_ip }}",
{% endif %}
{% if rule.ip_protocol is defined %}
            ip_protocol={{ rule.ip_protocol }},
{% endif %}
{% if rule.src_port is defined %}
            src_port={{ rule.src_port }},
{% endif %}
{% if rule.dst_port is defined %}
            dst_port={{ rule.dst_port }},
{% endif %}
{% if rule.src_port_range is defined %}
            src_port_range=({{ rule.src_port_range }}),
{% endif %}
{% if rule.dst_port_range is defined %}
            dst_port_range=({{ rule.dst_port_range }}),
{% endif %}
{% if rule.vxlan_vni is defined %}
            vxlan_vni={{ rule.vxlan_vni }},
{% endif %}
{% if rule.src_ipv6 is defined %}
            src_ipv6="{{ rule.src_ipv6 }}",
{% endif %}
{% if rule.dst_ipv6 is defined %}
            dst_ipv6="{{ rule.dst_ipv6 }}",
{% endif %}
{% if rule.ipv6_next_header is defined %}
            ipv6_next_header={{ rule.ipv6_next_header }},
{% endif %}
        ),
{% endfor %}
    ]
    return PacketFilterScoreboard(rules, default_action="{{ default_action }}")


def build_coverage():
    """Build the coverage model for this rule set."""
    cov = FilterCoverage(default_action="{{ default_action }}")
{% for rule in scoreboard_rules %}
    cov.add_rule("{{ rule.name }}")
{% endfor %}
    return cov


# ── Helpers ───────────────────────────────────────────────────────

async def setup(dut):
    """Common test setup: clock + reset."""
    clock = Clock(dut.clk, 10, unit="ns")
    cocotb.start_soon(clock.start())
    driver = PacketDriver(dut)
    monitor = DecisionMonitor(dut)
    await driver.reset()
    return driver, monitor


# ── Directed Tests (per-rule) ────────────────────────────────────
{% for tc in test_cases %}

@cocotb.test()
async def {{ tc.name }}(dut):
    """{{ tc.description }}"""
    driver, monitor = await setup(dut)
{% if tc.has_ipv6 is defined and tc.has_ipv6 == "true" %}
    # Construct IPv6 packet with proper headers
    _proto = {{ tc.ipv6_next_header | default(value='59') }}
    _payload_len = 8
    l4_payload = bytes(8)
{% if tc.dst_port is defined %}
    _src_port = {{ tc.src_port | default(value='12345') }}
    _dst_port = {{ tc.dst_port }}
    if _proto == 6:
        l4_payload = struct.pack("!HH", _src_port, _dst_port) + bytes(16)
        _payload_len = 20
    elif _proto == 17:
        l4_payload = struct.pack("!HHHH", _src_port, _dst_port, 28, 0) + bytes(20)
        _payload_len = 28
{% endif %}
    ipv6_hdr = Ipv6Header(
        src_addr="{{ tc.src_ipv6 | default(value='2001:0db8:0000:0000:0000:0000:0000:0001') }}",
        dst_addr="{{ tc.dst_ipv6 | default(value='2001:0db8:0000:0000:0000:0000:0000:0002') }}",
        next_header=_proto,
        payload_length=_payload_len,
    )
    payload = ipv6_hdr.to_bytes() + l4_payload
    extracted = {
        "src_ipv6": "{{ tc.src_ipv6 | default(value='2001:0db8:0000:0000:0000:0000:0000:0001') }}",
        "dst_ipv6": "{{ tc.dst_ipv6 | default(value='2001:0db8:0000:0000:0000:0000:0000:0002') }}",
        "ipv6_next_header": _proto,
{% if tc.dst_port is defined %}
        "src_port": _src_port,
        "dst_port": _dst_port,
{% endif %}
    }
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("{{ tc.dst_mac }}"),
        src_mac=mac_to_bytes("{{ tc.src_mac }}"),
        ethertype={{ tc.ethertype }},
        payload=payload,
    )
{% elif tc.has_l3 is defined and tc.has_l3 == "true" %}
    # Construct IPv4 packet with proper L3/L4 headers
    _ip_proto = {{ tc.ip_protocol | default(value='6') }}
    _src_ip = "{{ tc.src_ip | default(value='10.0.0.1') }}"
    _dst_ip = "{{ tc.dst_ip | default(value='10.0.0.2') }}"
    _src_port = {{ tc.src_port | default(value='12345') }}
    _dst_port = {{ tc.dst_port | default(value='80') }}
    if _ip_proto == 6:  # TCP
        l4_hdr = struct.pack("!HH", _src_port, _dst_port) + bytes(16)
    elif _ip_proto == 17:  # UDP
        l4_hdr = struct.pack("!HHHH", _src_port, _dst_port, 28, 0) + bytes(20)
    else:
        l4_hdr = bytes(20)
    ip_hdr = Ipv4Header(
        src_addr=_src_ip, dst_addr=_dst_ip,
        protocol=_ip_proto, total_length=20 + len(l4_hdr),
    )
    payload = ip_hdr.to_bytes() + l4_hdr
    extracted = {
        "src_ip": _src_ip,
        "dst_ip": _dst_ip,
        "ip_protocol": _ip_proto,
        "src_port": _src_port,
        "dst_port": _dst_port,
    }
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("{{ tc.dst_mac }}"),
        src_mac=mac_to_bytes("{{ tc.src_mac }}"),
        ethertype={{ tc.ethertype }},
        payload=payload,
    )
{% elif tc.has_vlan == "true" %}
    extracted = {}
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("{{ tc.dst_mac }}"),
        src_mac=mac_to_bytes("{{ tc.src_mac }}"),
        ethertype={{ tc.ethertype }},
        vlan_tag=VlanTag(vid={{ tc.vlan_id }}, pcp={{ tc.vlan_pcp }}),
        payload=bytes(46),
    )
{% else %}
    extracted = {}
    frame = EthernetFrame(
        dst_mac=mac_to_bytes("{{ tc.dst_mac }}"),
        src_mac=mac_to_bytes("{{ tc.src_mac }}"),
        ethertype={{ tc.ethertype }},
        payload=bytes(46),
    )
{% endif %}
    await driver.send(frame)
    result = await monitor.wait_for_decision()
    expected = {% if tc.expect_pass == "true" %}1{% else %}0{% endif %}
    assert result == expected, \
        f"{{ tc.name }}: expected decision_pass={expected}, got {result}"
    dut._log.info("{{ tc.name }}: PASSED (decision_pass=%d)", result)
{% endfor %}


# ── Constrained Random Test with Scoreboard ──────────────────────

@cocotb.test()
async def test_random_with_scoreboard(dut):
    """Constrained random: {{ num_rules }} rules, 500 random packets, scoreboard-checked."""
    driver, monitor = await setup(dut)
    scoreboard = build_scoreboard()
    coverage = build_coverage()

    # Define EtherType pool weighted toward rule-relevant values
    ethertype_pool = [
{% for rule in scoreboard_rules %}
{% if rule.ethertype is defined %}
        {{ rule.ethertype }},  # {{ rule.name }}
{% endif %}
{% endfor %}
        0x0800,   # IPv4
        0x86DD,   # IPv6
        0x88B5,   # Reserved (should miss all rules)
        0x88B5,   # Extra weight for default-action testing
    ]

    num_packets = 500
    for i in range(num_packets):
        # Randomly construct a frame
        etype = random.choice(ethertype_pool)

        # Vary MAC types
        mac_type = random.choice(["unicast", "broadcast", "multicast", "vendor"])
        if mac_type == "broadcast":
            dst = b"\xff\xff\xff\xff\xff\xff"
        elif mac_type == "multicast":
            dst = bytes([random.randint(0, 255) | 0x01] + [random.randint(0, 255) for _ in range(5)])
        elif mac_type == "vendor":
            dst = mac_to_bytes("00:1a:2b:aa:bb:cc")
        else:
            dst = bytes([random.randint(0, 254) & 0xFE] + [random.randint(0, 255) for _ in range(5)])

        src_type = random.choice(["normal", "vendor"])
        if src_type == "vendor":
            src = bytes([0x00, 0x1a, 0x2b] + [random.randint(0, 255) for _ in range(3)])
        else:
            src = bytes([random.randint(0, 254) & 0xFE] + [random.randint(0, 255) for _ in range(5)])

        # Vary frame sizes for coverage
        size_class = random.choices(
            ["runt", "min", "typical", "large", "jumbo"],
            weights=[5, 30, 40, 20, 5],
            k=1,
        )[0]
        if size_class == "runt":
            payload_len = random.randint(1, 45)
        elif size_class == "min":
            payload_len = 46
        elif size_class == "typical":
            payload_len = random.randint(64, 1000)
        elif size_class == "large":
            payload_len = random.randint(1001, 1486)
        else:  # jumbo
            payload_len = random.randint(1487, 9000)

        # Occasionally add VLAN tags
        vlan_tag = None
        if random.random() < 0.15:
            vlan_tag = VlanTag(
                vid=random.choice([1, 100, 200, 4094]),
                pcp=random.randint(0, 7),
            )

        # Build extracted fields dict for scoreboard L3/L4 matching
        extracted = {}
        payload = bytes(payload_len)

        # 50% of IPv4 frames get proper L3/L4 headers
        if etype == 0x0800 and random.random() < 0.5 and payload_len >= 40:
            _ip_proto = random.choice([6, 17, 1])
            _src_ip = f"{random.randint(1,223)}.{random.randint(0,255)}.{random.randint(0,255)}.{random.randint(1,254)}"
            _dst_ip = f"{random.randint(1,223)}.{random.randint(0,255)}.{random.randint(0,255)}.{random.randint(1,254)}"
            _src_port = random.randint(1024, 65535)
            _dst_port = random.choice([80, 443, 22, 53, 8080, random.randint(1, 65535)])
            if _ip_proto == 6:
                l4_hdr = struct.pack("!HH", _src_port, _dst_port) + bytes(16)
            elif _ip_proto == 17:
                l4_hdr = struct.pack("!HHHH", _src_port, _dst_port, 28, 0) + bytes(20)
            else:
                l4_hdr = bytes(20)
            ip_hdr = Ipv4Header(
                src_addr=_src_ip, dst_addr=_dst_ip,
                protocol=_ip_proto, total_length=20 + len(l4_hdr),
            )
            payload = ip_hdr.to_bytes() + l4_hdr + bytes(max(0, payload_len - 20 - len(l4_hdr)))
            extracted = {
                "src_ip": _src_ip, "dst_ip": _dst_ip,
                "ip_protocol": _ip_proto,
                "src_port": _src_port, "dst_port": _dst_port,
            }

        # 50% of IPv6 frames get proper L3 headers
        elif etype == 0x86DD and random.random() < 0.5 and payload_len >= 48:
            _nh = random.choice([6, 17, 58])
            _src_ipv6 = f"2001:db8:{random.randint(0,0xffff):04x}::{random.randint(1,0xffff):x}"
            _dst_ipv6 = f"2001:db8:{random.randint(0,0xffff):04x}::{random.randint(1,0xffff):x}"
            l4_payload = bytes(8)
            ip6_hdr = Ipv6Header(
                src_addr=_src_ipv6, dst_addr=_dst_ipv6,
                next_header=_nh, payload_length=8,
            )
            payload = ip6_hdr.to_bytes() + l4_payload + bytes(max(0, payload_len - 48))
            extracted = {
                "src_ipv6": _src_ipv6, "dst_ipv6": _dst_ipv6,
                "ipv6_next_header": _nh,
            }

        frame = EthernetFrame(
            dst_mac=dst,
            src_mac=src,
            ethertype=etype,
            payload=payload,
            vlan_tag=vlan_tag,
        )

        await driver.send(frame)
        result = await monitor.wait_for_decision()

        # Scoreboard check (pass extracted fields for L3/L4 matching)
        action, matched_rule = scoreboard.check(frame, result, extracted=extracted)

        # Coverage sample
        coverage.sample(frame, result == 1, matched_rule)

    # Report
    dut._log.info("\n%s", scoreboard.report())
    dut._log.info("\n%s", coverage.report())
    dut._log.info("Random test: %d/%d packets checked OK", num_packets, num_packets)
    dut._log.info("Coverage: %.1f%%", coverage.overall_coverage)


# ── Corner Case Tests ────────────────────────────────────────────

@cocotb.test()
async def test_back_to_back_frames(dut):
    """Stress: send frames with no inter-frame gap."""
    driver, monitor = await setup(dut)
    driver.inter_frame_gap = 0
    scoreboard = build_scoreboard()

    frames = [
        PacketFactory.arp(),
        PacketFactory.ipv4(),
        PacketFactory.arp(),
    ]

    for frame in frames:
        await driver.send(frame)
        result = await monitor.wait_for_decision()
        scoreboard.check(frame, result)

    dut._log.info("Back-to-back: 3 frames checked OK")


@cocotb.test()
async def test_jumbo_frame(dut):
    """Corner case: jumbo frame (9000 bytes)."""
    driver, monitor = await setup(dut)
    scoreboard = build_scoreboard()

    frame = PacketFactory.jumbo_frame(9000)
    await driver.send(frame)
    result = await monitor.wait_for_decision()
    scoreboard.check(frame, result)
    dut._log.info("Jumbo frame: decision_pass=%d", result)


@cocotb.test()
async def test_min_size_frame(dut):
    """Boundary: minimum Ethernet frame (64 bytes)."""
    driver, monitor = await setup(dut)
    scoreboard = build_scoreboard()

    frame = EthernetFrame(
        dst_mac=mac_to_bytes("de:ad:be:ef:00:01"),
        src_mac=mac_to_bytes("02:00:00:00:00:01"),
        ethertype=0x0806,
        payload=bytes(46),
    )
    assert len(frame) == 60  # 6+6+2+46 = 60 (64 with FCS, we don't include FCS)
    await driver.send(frame)
    result = await monitor.wait_for_decision()
    scoreboard.check(frame, result)
    dut._log.info("Min-size frame: decision_pass=%d", result)


@cocotb.test()
async def test_reset_recovery(dut):
    """Corner case: reset mid-operation, then send frame."""
    driver, monitor = await setup(dut)
    scoreboard = build_scoreboard()

    # Send partial frame then reset
    frame = PacketFactory.arp()
    frame_bytes = frame.to_bytes()
    for i, byte in enumerate(frame_bytes[:8]):
        dut.pkt_data.value = byte
        dut.pkt_valid.value = 1
        dut.pkt_sof.value = 1 if i == 0 else 0
        dut.pkt_eof.value = 0
        await RisingEdge(dut.clk)

    # Reset!
    await driver.reset()

    # Now send a complete frame — should work normally
    frame = PacketFactory.arp()
    await driver.send(frame)
    result = await monitor.wait_for_decision()
    scoreboard.check(frame, result)
    dut._log.info("Reset recovery: decision_pass=%d (expected pass)", result)
