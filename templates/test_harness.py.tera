import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, ClockCycles, Timer


def mac_to_bytes(mac_str):
    """Convert MAC string 'aa:bb:cc:dd:ee:ff' to list of ints."""
    return [int(x, 16) for x in mac_str.split(":")]


def ethertype_to_bytes(et_str):
    """Convert ethertype string '0x0806' to [high_byte, low_byte]."""
    val = int(et_str, 16)
    return [(val >> 8) & 0xFF, val & 0xFF]


async def reset_dut(dut):
    """Apply reset for a few cycles."""
    dut.rst_n.value = 0
    dut.pkt_valid.value = 0
    dut.pkt_sof.value = 0
    dut.pkt_eof.value = 0
    dut.pkt_data.value = 0
    await ClockCycles(dut.clk, 5)
    dut.rst_n.value = 1
    await ClockCycles(dut.clk, 2)


async def send_frame(dut, dst_mac, src_mac, ethertype, payload=None):
    """
    Send an Ethernet frame byte-by-byte.
    dst_mac, src_mac: "aa:bb:cc:dd:ee:ff"
    ethertype: "0x0806"
    payload: list of ints (optional, defaults to 46 zero bytes for min frame)
    """
    if payload is None:
        payload = [0x00] * 46  # minimum Ethernet payload

    frame_bytes = mac_to_bytes(dst_mac) + mac_to_bytes(src_mac) + ethertype_to_bytes(ethertype) + payload

    for i, byte in enumerate(frame_bytes):
        dut.pkt_data.value = byte
        dut.pkt_valid.value = 1
        dut.pkt_sof.value = 1 if i == 0 else 0
        dut.pkt_eof.value = 1 if i == len(frame_bytes) - 1 else 0
        await RisingEdge(dut.clk)

    # Deassert valid after frame
    dut.pkt_valid.value = 0
    dut.pkt_sof.value = 0
    dut.pkt_eof.value = 0
    await RisingEdge(dut.clk)


async def wait_for_decision(dut, timeout_cycles=200):
    """Wait for decision_valid to assert, return decision_pass value."""
    for _ in range(timeout_cycles):
        await RisingEdge(dut.clk)
        if dut.decision_valid.value == 1:
            return int(dut.decision_pass.value)
    raise TimeoutError("decision_valid never asserted")

{% for tc in test_cases %}

@cocotb.test()
async def {{ tc.name }}(dut):
    """{{ tc.description }}"""
    clock = Clock(dut.clk, 10, unit="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    await send_frame(
        dut,
        dst_mac="{{ tc.dst_mac }}",
        src_mac="{{ tc.src_mac }}",
        ethertype="{{ tc.ethertype }}"
    )

    result = await wait_for_decision(dut)
    expected = {% if tc.expect_pass == "true" %}1{% else %}0{% endif %}
    assert result == expected, \
        f"{{ tc.name }}: expected decision_pass={expected}, got {result}"
    dut._log.info("{{ tc.name }}: PASSED (decision_pass=%d)", result)
{% endfor %}
