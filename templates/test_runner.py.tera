"""
run_sim.py — cocotb 2.0 programmatic simulation runner
Generated by pacgate — do not edit

Usage:
    python run_sim.py              # Run with Icarus Verilog (default)
    SIM=questa python run_sim.py   # Run with Questa/QuestaSim
    SIM=verilator python run_sim.py  # Run with Verilator
"""

import os
from cocotb_tools.runner import get_runner


def main():
    sim = os.environ.get("SIM", "icarus")
    runner = get_runner(sim)

    verilog_sources = [
        {% for f in verilog_files %}"{{ f }}",
        {% endfor %}
    ]

    runner.build(
        verilog_sources=verilog_sources,
        hdl_toplevel="{{ module_name }}",
        always=True,
    )

    runner.test(
        hdl_toplevel="{{ module_name }}",
        test_module="{{ test_module }}",
        results_xml="results.xml",
    )


if __name__ == "__main__":
    main()
