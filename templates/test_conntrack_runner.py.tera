    runner.build(
        verilog_sources=["../../rtl/conntrack_table.v"],
        hdl_toplevel="conntrack_table",
        always=True,
    )

    runner.test(
        hdl_toplevel="conntrack_table",
        test_module="test_conntrack",
        results_xml="results.xml",
    )


if __name__ == "__main__":
    main()
