<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PacGate Rule Diff Report</title>
<style>
  :root {
    --bg: #1e1e2e;
    --surface: #313244;
    --text: #cdd6f4;
    --subtext: #a6adc8;
    --green: #a6e3a1;
    --red: #f38ba8;
    --yellow: #f9e2af;
    --blue: #89b4fa;
    --border: #45475a;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; padding: 2rem; }
  h1 { color: var(--blue); margin-bottom: 0.5rem; }
  .meta { color: var(--subtext); margin-bottom: 2rem; font-size: 0.9rem; }
  .summary { display: flex; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .summary-card {
    background: var(--surface); border-radius: 8px; padding: 1rem 1.5rem;
    border-left: 4px solid var(--border); min-width: 120px;
  }
  .summary-card.added { border-left-color: var(--green); }
  .summary-card.removed { border-left-color: var(--red); }
  .summary-card.modified { border-left-color: var(--yellow); }
  .summary-card.unchanged { border-left-color: var(--subtext); }
  .summary-card .count { font-size: 2rem; font-weight: bold; }
  .summary-card .label { color: var(--subtext); font-size: 0.85rem; }
  .section { margin-bottom: 2rem; }
  .section h2 { color: var(--subtext); font-size: 1.1rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 8px; overflow: hidden; }
  th { background: var(--border); text-align: left; padding: 0.6rem 1rem; font-weight: 600; font-size: 0.85rem; color: var(--subtext); }
  td { padding: 0.6rem 1rem; border-bottom: 1px solid var(--border); font-size: 0.9rem; }
  tr:last-child td { border-bottom: none; }
  .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: 600; }
  .badge-added { background: rgba(166,227,161,0.15); color: var(--green); }
  .badge-removed { background: rgba(243,139,168,0.15); color: var(--red); }
  .badge-modified { background: rgba(249,226,175,0.15); color: var(--yellow); }
  .change-row { font-family: monospace; font-size: 0.85rem; }
  .old-val { color: var(--red); text-decoration: line-through; }
  .new-val { color: var(--green); }
  .arrow { color: var(--subtext); margin: 0 0.4rem; }
  .default-change { background: rgba(249,226,175,0.1); padding: 0.75rem 1rem; border-radius: 6px; border: 1px solid rgba(249,226,175,0.3); margin-bottom: 1.5rem; }
  .side-by-side { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .side-panel { background: var(--surface); border-radius: 8px; padding: 1rem; }
  .side-panel h3 { color: var(--subtext); font-size: 0.9rem; margin-bottom: 0.5rem; }
  .rule-detail { font-family: monospace; font-size: 0.85rem; line-height: 1.6; }
  .field-label { color: var(--subtext); }
  footer { margin-top: 3rem; color: var(--subtext); font-size: 0.8rem; text-align: center; }
</style>
</head>
<body>
<h1>PacGate Rule Diff Report</h1>
<div class="meta">
  Old: <strong>{{ old_file }}</strong> ({{ old_rule_count }} rules) &rarr;
  New: <strong>{{ new_file }}</strong> ({{ new_rule_count }} rules)
  &nbsp;|&nbsp; Generated: {{ timestamp }}
</div>

{% if default_changed %}
<div class="default-change">
  Default action changed: <span class="old-val">{{ old_default }}</span>
  <span class="arrow">&rarr;</span>
  <span class="new-val">{{ new_default }}</span>
</div>
{% endif %}

<div class="summary">
  <div class="summary-card added">
    <div class="count">{{ added_count }}</div>
    <div class="label">Added</div>
  </div>
  <div class="summary-card removed">
    <div class="count">{{ removed_count }}</div>
    <div class="label">Removed</div>
  </div>
  <div class="summary-card modified">
    <div class="count">{{ modified_count }}</div>
    <div class="label">Modified</div>
  </div>
  <div class="summary-card unchanged">
    <div class="count">{{ unchanged_count }}</div>
    <div class="label">Unchanged</div>
  </div>
</div>

{% if added | length > 0 %}
<div class="section">
  <h2>Added Rules</h2>
  <table>
    <tr><th>Rule Name</th><th>Priority</th><th>Action</th><th>Match Criteria</th></tr>
    {% for rule in added %}
    <tr>
      <td><span class="badge badge-added">+ {{ rule.name }}</span></td>
      <td>{{ rule.priority }}</td>
      <td>{{ rule.action }}</td>
      <td class="change-row">{{ rule.criteria }}</td>
    </tr>
    {% endfor %}
  </table>
</div>
{% endif %}

{% if removed | length > 0 %}
<div class="section">
  <h2>Removed Rules</h2>
  <table>
    <tr><th>Rule Name</th><th>Priority</th><th>Action</th><th>Match Criteria</th></tr>
    {% for rule in removed %}
    <tr>
      <td><span class="badge badge-removed">- {{ rule.name }}</span></td>
      <td>{{ rule.priority }}</td>
      <td>{{ rule.action }}</td>
      <td class="change-row">{{ rule.criteria }}</td>
    </tr>
    {% endfor %}
  </table>
</div>
{% endif %}

{% if modified | length > 0 %}
<div class="section">
  <h2>Modified Rules</h2>
  {% for rule in modified %}
  <div class="side-by-side" style="margin-bottom: 1rem;">
    <div class="side-panel">
      <h3><span class="badge badge-modified">~ {{ rule.name }}</span> &mdash; Old</h3>
      <div class="rule-detail">
        <span class="field-label">priority:</span> {{ rule.old_priority }}<br>
        <span class="field-label">action:</span> {{ rule.old_action }}<br>
        <span class="field-label">criteria:</span> {{ rule.old_criteria }}
      </div>
    </div>
    <div class="side-panel">
      <h3><span class="badge badge-modified">~ {{ rule.name }}</span> &mdash; New</h3>
      <div class="rule-detail">
        <span class="field-label">priority:</span> {{ rule.new_priority }}<br>
        <span class="field-label">action:</span> {{ rule.new_action }}<br>
        <span class="field-label">criteria:</span> {{ rule.new_criteria }}
      </div>
    </div>
  </div>
  <table style="margin-bottom: 1.5rem;">
    <tr><th>Field</th><th>Old Value</th><th>New Value</th></tr>
    {% for change in rule.changes %}
    <tr>
      <td>{{ change.field }}</td>
      <td class="old-val">{{ change.old_value }}</td>
      <td class="new-val">{{ change.new_value }}</td>
    </tr>
    {% endfor %}
  </table>
  {% endfor %}
</div>
{% endif %}

<footer>
  Generated by PacGate &mdash; FPGA Packet Filter Gate
</footer>
</body>
</html>
