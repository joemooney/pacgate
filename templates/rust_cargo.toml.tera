[package]
name = "pacgate_filter"
version = "0.1.0"
edition = "2021"
# Generated by pacgate --target rust from {{ rules_file }}
# {{ num_rules }} rules, default action: {{ default_action }}

[features]
default = []
afxdp = ["dep:aya", "dep:tokio"]

[dependencies]
aya = { version = "0.13", optional = true, features = ["async_tokio"] }
tokio = { version = "1", optional = true, features = ["rt", "macros"] }

[profile.release]
opt-level = 3
lto = true
