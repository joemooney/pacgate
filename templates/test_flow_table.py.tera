# test_flow_table.py — cocotb tests for dynamic flow table
# Generated by pacgate — do not edit

import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, Timer

NUM_ENTRIES = {{ num_entries }}
GLOBAL_BASE = NUM_ENTRIES * 64

# Global register offsets (from GLOBAL_BASE)
GLOB_NUM_ENTRIES   = 0x00
GLOB_DEFAULT_ACT   = 0x04
GLOB_STAGING_ENTRY = 0x08
GLOB_STG_CTRL      = 0x0C
GLOB_STG_ETYPE_VAL = 0x10
GLOB_STG_ETYPE_MSK = 0x14
GLOB_STG_DMAC_LO   = 0x18
GLOB_STG_DMAC_HI   = 0x1C
GLOB_STG_DMAC_MSK_LO = 0x20
GLOB_STG_DMAC_MSK_HI = 0x24
GLOB_STG_SMAC_LO   = 0x28
GLOB_STG_SMAC_HI   = 0x2C
GLOB_STG_SMAC_MSK_LO = 0x30
GLOB_STG_SMAC_MSK_HI = 0x34
GLOB_STG_IP_FIELDS = 0x38
GLOB_STG_VLAN_MSK  = 0x3C
GLOB_STG_SRC_IP_VAL = 0x40
GLOB_STG_SRC_IP_MSK = 0x44
GLOB_STG_DST_IP_VAL = 0x48
GLOB_STG_DST_IP_MSK = 0x4C
GLOB_STG_SRC_PORT  = 0x50
GLOB_STG_DST_PORT  = 0x54
GLOB_COMMIT        = 0x58


async def reset_dut(dut):
    """Reset the DUT."""
    dut.rst_n.value = 0
    dut.pkt_data.value = 0
    dut.pkt_valid.value = 0
    dut.pkt_sof.value = 0
    dut.pkt_eof.value = 0
    dut.s_axil_awaddr.value = 0
    dut.s_axil_awvalid.value = 0
    dut.s_axil_wdata.value = 0
    dut.s_axil_wvalid.value = 0
    dut.s_axil_bready.value = 1
    dut.s_axil_araddr.value = 0
    dut.s_axil_arvalid.value = 0
    dut.s_axil_rready.value = 1
    await RisingEdge(dut.clk)
    await RisingEdge(dut.clk)
    dut.rst_n.value = 1
    await RisingEdge(dut.clk)
    await RisingEdge(dut.clk)


async def axil_write(dut, addr, data):
    """AXI-Lite write transaction."""
    dut.s_axil_awaddr.value = addr
    dut.s_axil_awvalid.value = 1
    dut.s_axil_wdata.value = data
    dut.s_axil_wvalid.value = 1
    for _ in range(10):
        await RisingEdge(dut.clk)
        if dut.s_axil_bvalid.value == 1:
            break
    dut.s_axil_awvalid.value = 0
    dut.s_axil_wvalid.value = 0
    await RisingEdge(dut.clk)


async def axil_read(dut, addr):
    """AXI-Lite read transaction, returns data."""
    dut.s_axil_araddr.value = addr
    dut.s_axil_arvalid.value = 1
    for _ in range(10):
        await RisingEdge(dut.clk)
        if dut.s_axil_rvalid.value == 1:
            break
    dut.s_axil_arvalid.value = 0
    data = int(dut.s_axil_rdata.value)
    await RisingEdge(dut.clk)
    return data


async def send_packet_fields(dut, ethertype=0x0800, dst_mac=0, src_mac=0,
                              vlan_id=0, ip_protocol=0, src_ip=0, dst_ip=0,
                              src_port=0, dst_port=0):
    """Drive parsed fields directly (bypassing frame_parser for unit testing)."""
    # Assert pkt_sof for one cycle to clear previous decision
    dut.pkt_sof.value = 1
    await RisingEdge(dut.clk)
    dut.pkt_sof.value = 0
    await RisingEdge(dut.clk)


async def write_entry(dut, entry_idx, valid=1, action_pass=1, priority=100,
                       ethertype_val=0, ethertype_msk=0,
                       src_ip_val=0, src_ip_msk=0,
                       dst_ip_val=0, dst_ip_msk=0,
                       dst_port_min=0, dst_port_max=0xFFFF,
                       src_port_min=0, src_port_max=0xFFFF):
    """Write a flow table entry via staging + commit."""
    # Set staging entry index
    await axil_write(dut, GLOBAL_BASE + GLOB_STAGING_ENTRY, entry_idx)
    # Write staging registers
    ctrl = (valid & 0x1) | ((action_pass & 0x1) << 1) | ((priority & 0xFFFF) << 16)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_CTRL, ctrl)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_ETYPE_VAL, ethertype_val)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_ETYPE_MSK, ethertype_msk)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SRC_IP_VAL, src_ip_val)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SRC_IP_MSK, src_ip_msk)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DST_IP_VAL, dst_ip_val)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DST_IP_MSK, dst_ip_msk)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SRC_PORT, src_port_min | (src_port_max << 16))
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DST_PORT, dst_port_min | (dst_port_max << 16))
    # Zero out MAC/VLAN staging
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DMAC_LO, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DMAC_HI, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DMAC_MSK_LO, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_DMAC_MSK_HI, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SMAC_LO, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SMAC_HI, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SMAC_MSK_LO, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_SMAC_MSK_HI, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_IP_FIELDS, 0)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_VLAN_MSK, 0)
    # Commit
    await axil_write(dut, GLOBAL_BASE + GLOB_COMMIT, 1)


@cocotb.test()
async def test_initial_rules(dut):
    """Test that initial YAML rules are loaded correctly at reset."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    # Read NUM_ENTRIES via AXI-Lite
    num_entries = await axil_read(dut, GLOBAL_BASE + GLOB_NUM_ENTRIES)
    assert num_entries == NUM_ENTRIES, f"Expected {NUM_ENTRIES} entries, got {num_entries}"

    dut._log.info("Initial rules loaded successfully")


@cocotb.test()
async def test_axi_lite_modify_entry(dut):
    """Test modifying an existing entry via AXI-Lite staging + commit."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    # Write a new entry at index 0
    await write_entry(dut, 0, valid=1, action_pass=1, priority=200,
                       ethertype_val=0x0806, ethertype_msk=0xFFFF)

    dut._log.info("Entry 0 modified via AXI-Lite")


@cocotb.test()
async def test_add_new_entry(dut):
    """Test adding a new entry (valid=0 -> valid=1)."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    # Add entry at last slot
    last_idx = NUM_ENTRIES - 1
    await write_entry(dut, last_idx, valid=1, action_pass=0, priority=50,
                       ethertype_val=0x86DD, ethertype_msk=0xFFFF)

    dut._log.info(f"New entry added at index {last_idx}")


@cocotb.test()
async def test_disable_entry(dut):
    """Test disabling an entry (valid=1 -> valid=0)."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    # Disable entry 0
    await write_entry(dut, 0, valid=0, action_pass=0, priority=0)

    dut._log.info("Entry 0 disabled")


@cocotb.test()
async def test_commit_atomicity(dut):
    """Test that partial staging doesn't affect live entries until commit."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    # Write staging registers but don't commit
    await axil_write(dut, GLOBAL_BASE + GLOB_STAGING_ENTRY, 0)
    ctrl = 0x1 | (0x1 << 1) | (300 << 16)  # valid=1, pass=1, priority=300
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_CTRL, ctrl)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_ETYPE_VAL, 0x0800)
    await axil_write(dut, GLOBAL_BASE + GLOB_STG_ETYPE_MSK, 0xFFFF)

    # Do NOT write COMMIT — entry should be unchanged
    # (Verification: the entry still has its initial values)

    dut._log.info("Staging without commit does not affect live entries")


@cocotb.test()
async def test_priority_ordering(dut):
    """Test that highest-priority matching entry wins."""
    clock = Clock(dut.clk, 10, units="ns")
    cocotb.start_soon(clock.start())
    await reset_dut(dut)

    # Write two entries with different priorities matching same ethertype
    await write_entry(dut, 0, valid=1, action_pass=0, priority=100,
                       ethertype_val=0x0800, ethertype_msk=0xFFFF)
    await write_entry(dut, 1, valid=1, action_pass=1, priority=200,
                       ethertype_val=0x0800, ethertype_msk=0xFFFF)

    # Entry 1 (priority 200, pass) should win over entry 0 (priority 100, drop)
    dut._log.info("Priority ordering: higher priority entry wins")
