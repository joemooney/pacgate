"""
test_conntrack.py — cocotb tests for connection tracking table
Generated by pacgate — do not edit

Tests:
  - New flow insertion
  - Return traffic matching
  - Flow timeout expiry
  - Hash collision handling
  - Table overflow behavior
"""

import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, ClockCycles


async def setup(dut):
    """Common test setup: clock + reset."""
    clock = Clock(dut.clk, 10, unit="ns")
    cocotb.start_soon(clock.start())
    dut.rst_n.value = 0
    await ClockCycles(dut.clk, 5)
    dut.rst_n.value = 1
    await ClockCycles(dut.clk, 2)

    # Initialize inputs
    dut.lookup_valid.value = 0
    dut.insert_valid.value = 0
    await RisingEdge(dut.clk)


async def insert_flow(dut, src_ip, dst_ip, src_port, dst_port, protocol):
    """Insert a flow into the connection tracking table."""
    dut.insert_valid.value = 1
    dut.insert_src_ip.value = src_ip
    dut.insert_dst_ip.value = dst_ip
    dut.insert_src_port.value = src_port
    dut.insert_dst_port.value = dst_port
    dut.insert_protocol.value = protocol
    await RisingEdge(dut.clk)
    dut.insert_valid.value = 0
    await ClockCycles(dut.clk, 3)


async def lookup_flow(dut, src_ip, dst_ip, src_port, dst_port, protocol):
    """Lookup a flow in the connection tracking table."""
    dut.lookup_valid.value = 1
    dut.lookup_src_ip.value = src_ip
    dut.lookup_dst_ip.value = dst_ip
    dut.lookup_src_port.value = src_port
    dut.lookup_dst_port.value = dst_port
    dut.lookup_protocol.value = protocol
    await RisingEdge(dut.clk)
    dut.lookup_valid.value = 0
    # Wait for lookup result
    for _ in range(10):
        await RisingEdge(dut.clk)
        if dut.lookup_result_valid.value == 1:
            return int(dut.lookup_hit.value)
    return None  # timeout


@cocotb.test()
async def test_conntrack_new_flow(dut):
    """New 5-tuple flow should be inserted and found on lookup."""
    await setup(dut)

    # Insert a TCP flow: 10.0.0.1:1234 -> 10.0.0.2:80
    await insert_flow(dut, 0x0A000001, 0x0A000002, 1234, 80, 6)

    # Lookup the same flow
    hit = await lookup_flow(dut, 0x0A000001, 0x0A000002, 1234, 80, 6)
    assert hit == 1, f"Expected flow hit, got {hit}"
    dut._log.info("test_conntrack_new_flow: PASSED")


@cocotb.test()
async def test_conntrack_return_traffic(dut):
    """Reverse flow (return traffic) should also be found."""
    await setup(dut)

    # Insert forward flow: 10.0.0.1:1234 -> 10.0.0.2:80
    await insert_flow(dut, 0x0A000001, 0x0A000002, 1234, 80, 6)

    # Lookup reverse flow: 10.0.0.2:80 -> 10.0.0.1:1234
    hit = await lookup_flow(dut, 0x0A000002, 0x0A000001, 80, 1234, 6)
    # Note: Whether reverse flow is tracked depends on implementation.
    # Some conntrack tables store both directions, others use symmetric hash.
    dut._log.info("test_conntrack_return_traffic: reverse lookup hit=%s", hit)


@cocotb.test()
async def test_conntrack_timeout(dut):
    """Flow should expire after timeout period."""
    await setup(dut)

    # Insert a flow
    await insert_flow(dut, 0x0A000001, 0x0A000002, 5555, 443, 6)

    # Verify it exists
    hit = await lookup_flow(dut, 0x0A000001, 0x0A000002, 5555, 443, 6)
    assert hit == 1, f"Expected hit before timeout, got {hit}"

    # Wait long enough for timeout (implementation-specific)
    # For testing, advance many cycles
    await ClockCycles(dut.clk, 5000)

    # Lookup again — may have timed out depending on config
    hit = await lookup_flow(dut, 0x0A000001, 0x0A000002, 5555, 443, 6)
    dut._log.info("test_conntrack_timeout: after 5000 cycles, hit=%s", hit)


@cocotb.test()
async def test_conntrack_hash_collision(dut):
    """Two different flows that may hash to the same bucket."""
    await setup(dut)

    # Insert two flows (different 5-tuples)
    await insert_flow(dut, 0x0A000001, 0x0A000002, 1234, 80, 6)
    await insert_flow(dut, 0xC0A80001, 0xC0A80002, 5678, 443, 6)

    # Both should be found
    hit1 = await lookup_flow(dut, 0x0A000001, 0x0A000002, 1234, 80, 6)
    hit2 = await lookup_flow(dut, 0xC0A80001, 0xC0A80002, 5678, 443, 6)

    dut._log.info("test_conntrack_hash_collision: flow1=%s, flow2=%s", hit1, hit2)
    # At least one should hit (linear probing resolves collisions)
    assert hit1 == 1 or hit2 == 1, "Neither flow found after hash collision"


@cocotb.test()
async def test_conntrack_table_full(dut):
    """Graceful handling when connection table is full."""
    await setup(dut)

    # Insert many flows to fill the table
    inserted = 0
    for i in range(256):  # More than typical table size
        src_ip = 0x0A000000 | (i & 0xFF)
        await insert_flow(dut, src_ip, 0x0A000002, 1000 + i, 80, 6)
        inserted += 1

    # Table should handle overflow gracefully (no crash/hang)
    # Lookup a recently inserted flow
    hit = await lookup_flow(dut, 0x0A0000FF, 0x0A000002, 1255, 80, 6)
    dut._log.info("test_conntrack_table_full: inserted=%d, last_lookup=%s", inserted, hit)
