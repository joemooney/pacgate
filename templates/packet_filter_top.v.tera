        .igmp_type    (igmp_type),
        .igmp_valid   (igmp_valid),
        .mld_type     (mld_type),
        .mld_valid    (mld_valid),
        .ip_dscp      (ip_dscp),
        .ip_ecn       (ip_ecn),
        .ipv6_dscp    (ipv6_dscp),
        .ipv6_ecn     (ipv6_ecn),
        .tcp_flags    (tcp_flags),
        .tcp_flags_valid (tcp_flags_valid),
        .icmp_type_field (icmp_type_field),
        .icmp_code    (icmp_code),
        .icmp_valid   (icmp_valid),
        .icmpv6_type  (icmpv6_type),
        .icmpv6_code  (icmpv6_code),
