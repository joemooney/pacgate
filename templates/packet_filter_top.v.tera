        .outer_vlan_pcp  (outer_vlan_pcp),
{% endif %}
{% if has_ip_frag %}
        .ip_dont_fragment  (ip_dont_fragment),
        .ip_more_fragments (ip_more_fragments),
        .ip_frag_offset    (ip_frag_offset),
{% endif %}
{% if has_gre %}
        .gre_protocol      (gre_protocol),
        .gre_key           (gre_key),
{% endif %}
{% if has_byte_capture %}
{% for cap in byte_captures %}
        .byte_cap_{{ cap.offset }}  (byte_cap_{{ cap.offset }}),
{% endfor %}
{% endif %}
        .fields_valid (fields_valid),
        .match_hit    (match_hit_{{ rule.index }}),
        .match_action (match_action_{{ rule.index }})
    );
{% endfor %}

    // Decision logic (priority encoder)
    decision_logic u_decision (
        .clk            (clk),
        .rst_n          (rst_n),
        .fields_valid   (fields_valid),
        .pkt_sof        (pkt_sof),
{% for rule in rules %}
