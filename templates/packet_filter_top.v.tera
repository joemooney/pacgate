        .src_ip       (src_ip),
        .dst_ip       (dst_ip),
        .ip_protocol  (ip_protocol),
        .ip_ttl       (ip_ttl),
        .ip_checksum  (ip_checksum),
        .l3_valid     (l3_valid),
        .ip_dont_fragment  (ip_dont_fragment),
        .ip_more_fragments (ip_more_fragments),
        .ip_frag_offset    (ip_frag_offset),
        .ip_frag_valid     (ip_frag_valid),
        .src_ipv6     (src_ipv6),
        .dst_ipv6     (dst_ipv6),
        .ipv6_next_header (ipv6_next_header),
        .ipv6_valid   (ipv6_valid),
        .src_port     (src_port),
        .dst_port     (dst_port),
        .l4_valid     (l4_valid),
        .l4_port_offset       (l4_port_offset),
        .l4_port_offset_valid (l4_port_offset_valid),
        .vxlan_vni    (vxlan_vni),
