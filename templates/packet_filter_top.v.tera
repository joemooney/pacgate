        .arp_valid    (arp_valid),
        .ipv6_hop_limit  (ipv6_hop_limit),
        .ipv6_flow_label (ipv6_flow_label),
        .gre_protocol    (gre_protocol),
        .gre_key         (gre_key),
        .gre_valid       (gre_valid),
        .fields_valid (fields_valid)
    );

{% if has_byte_capture %}
    // Byte capture module
{% for cap in byte_captures %}
    wire [{{ cap.bit_width - 1 }}:0] byte_cap_{{ cap.offset }};
{% endfor %}
    wire captures_valid;

    byte_capture u_byte_capture (
        .clk            (clk),
        .rst_n          (rst_n),
        .pkt_data       (pkt_data),
        .pkt_valid      (pkt_valid),
        .pkt_sof        (pkt_sof),
        .pkt_eof        (pkt_eof),
{% for cap in byte_captures %}
        .byte_cap_{{ cap.offset }}  (byte_cap_{{ cap.offset }}),
{% endfor %}
        .captures_valid (captures_valid)
    );
{% endif %}

    // Per-rule matchers (stateless: combinational, stateful: registered FSM)
{% for rule in rules %}
    wire match_hit_{{ rule.index }};
    wire match_action_{{ rule.index }};

    rule_match_{{ rule.index }} u_rule_{{ rule.index }} (
{% if rule.is_fsm == "true" %}
        .clk          (clk),
        .rst_n        (rst_n),
{% endif %}
        .dst_mac      (dst_mac),
        .src_mac      (src_mac),
        .ethertype    (ethertype),
        .vlan_id      (vlan_id),
        .vlan_pcp     (vlan_pcp),
        .src_ip       (src_ip),
        .dst_ip       (dst_ip),
        .ip_protocol  (ip_protocol),
        .src_port     (src_port),
        .dst_port     (dst_port),
        .vxlan_vni    (vxlan_vni),
{% if has_ipv6 %}
        .src_ipv6     (src_ipv6),
        .dst_ipv6     (dst_ipv6),
        .ipv6_next_header (ipv6_next_header),
{% endif %}
{% if has_gtp %}
