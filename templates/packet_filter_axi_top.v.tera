        .rule_idx   (decision_rule_idx),
        .rule_valid (decision_valid & ~decision_default),
        .int_enable (int_lut_enable)
    );
{% else %}
    assign int_lut_enable = 1'b0;
{% endif %}

    // Free-running 64-bit timestamp for INT (or use PTP clock if available)
{% if has_ptp %}
    // PTP clock timestamp is available externally
    wire [63:0] int_timestamp;
    reg [63:0] int_free_counter;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n)
            int_free_counter <= 64'd0;
        else
            int_free_counter <= int_free_counter + 1;
    end
    assign int_timestamp = int_free_counter;
{% else %}
    reg [63:0] int_timestamp;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n)
            int_timestamp <= 64'd0;
        else
            int_timestamp <= int_timestamp + 1;
    end
{% endif %}

    int_metadata #(
        .SWITCH_ID_DEFAULT ({{ int_switch_id }})
    ) u_int_metadata (
        .clk             (clk),
        .rst             (~rst_n),
        .pkt_sof         (pkt_sof),
        .pkt_eof         (pkt_eof),
        .pkt_valid       (pkt_valid),
        .decision_valid  (decision_valid),
        .decision_pass   (decision_pass),
        .decision_rule_idx ({% if idx_bits < 8 %}{ {{8 - idx_bits}}'d0, decision_rule_idx }{% else %}decision_rule_idx{% endif %}),
        .int_enable_pkt  (int_lut_enable),
{% if rss_enabled %}
        .rss_queue_id    (rss_queue_id),
        .rss_queue_valid (rss_queue_valid),
{% else %}
        .rss_queue_id    (4'd0),
        .rss_queue_valid (1'b0),
{% endif %}
        .timestamp       (int_timestamp),
        // AXI-Lite interface (active but unused for now — tie off)
        .axi_awvalid     (1'b0),
        .axi_awready     (),
        .axi_awaddr      (4'd0),
        .axi_wdata       (32'd0),
        .axi_wvalid      (1'b0),
        .axi_wready      (),
        .axi_araddr      (4'd0),
        .axi_arvalid     (1'b0),
        .axi_arready     (),
        .axi_rdata       (),
        .axi_rvalid      (),
        // INT metadata output
        .int_meta_valid  (int_meta_valid),
        .int_switch_id   (int_switch_id),
        .int_ingress_ts  (int_ingress_ts),
        .int_egress_ts   (int_egress_ts),
        .int_hop_latency (int_hop_latency),
        .int_queue_id    (int_queue_id),
        .int_rule_idx    (int_rule_idx)
    );
{% endif %}

{% if has_flow_counters %}
    // --- Per-flow counters via conntrack_table ---
    // The conntrack_table instance provides per-flow packet/byte counters
    // with a registered read-back interface (1-cycle latency on flow_read_en).
    // The flow_read_* ports are wired directly to the top-level for external access.

    // Free-running timestamp counter for conntrack timeout
    reg [31:0] ct_timestamp;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n)
            ct_timestamp <= 32'd0;
        else
            ct_timestamp <= ct_timestamp + 32'd1;
    end

    conntrack_table u_conntrack (
        .clk               (clk),
        .rst_n             (rst_n),
        .timestamp         (ct_timestamp),
        .tcp_flags_in      (8'd0),
        .pkt_len_in        (16'd0),
        .key_in            ({104{1'b0}}),
        .lookup_valid      (1'b0),
        .lookup_hit        (),
        .lookup_done       (),
        .flow_state        (),
        .flow_state_valid  (),
        .insert_en         (1'b0),
        .insert_key        ({104{1'b0}}),
        .insert_done       (),
        .insert_ok         (),
        .flow_read_idx     (flow_read_idx),
        .flow_read_en      (flow_read_en),
        .flow_read_key     (flow_read_key),
        .flow_read_valid   (flow_read_valid),
        .flow_read_pkt_count  (flow_read_pkt_count),
        .flow_read_byte_count (flow_read_byte_count),
        .flow_read_tcp_state  (flow_read_tcp_state),
        .flow_read_done    (flow_read_done)
    );
{% endif %}

endmodule
