{% endif %}

{% if rss_enabled %}
    // --- RSS (Receive Side Scaling) —
    // Toeplitz hash of 5-tuple → indirection table → queue assignment
    // Per-rule rss_queue override via rss_queue_lut takes priority

    wire [319:0] rss_hash_key;
    wire [31:0]  rss_hash_value;
    wire         rss_hash_valid;
{% if has_rss_queue_lut %}
    wire [3:0]   rss_override_queue;
    wire         rss_override_valid;

    rss_queue_lut u_rss_queue_lut (
