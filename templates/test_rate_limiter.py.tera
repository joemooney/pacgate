"""
test_rate_limiter.py — cocotb testbench for rate_limiter.v
Generated by pacgate — do not edit

Tests the token-bucket rate limiter module:
  - Initial burst availability
  - Rate drop after burst exhaustion
  - Token refill after interval
  - Upstream drop passthrough
  - Token cap (never exceeds BURST)
"""

import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, ClockCycles


async def setup(dut):
    """Common test setup: clock + reset."""
    clock = Clock(dut.clk, 10, unit="ns")  # 100 MHz
    cocotb.start_soon(clock.start())

    dut.rst_n.value = 0
    dut.pass_in.value = 0
    dut.decision_valid.value = 0
    await ClockCycles(dut.clk, 5)
    dut.rst_n.value = 1
    await ClockCycles(dut.clk, 5)


async def send_packet(dut, pass_in=1):
    """Simulate a packet arriving and check rate limiter decision."""
    dut.pass_in.value = pass_in
    dut.decision_valid.value = 1
    await RisingEdge(dut.clk)
    dut.decision_valid.value = 0
    await RisingEdge(dut.clk)
    return dut.pass_out.value.integer


@cocotb.test()
async def test_initial_burst(dut):
    """After reset, all BURST tokens should be available."""
    await setup(dut)

    # Send BURST packets — all should pass
    burst = int(dut.BURST.value)
    passed = 0
    for _ in range(burst):
        result = await send_packet(dut, pass_in=1)
        if result == 1:
            passed += 1

    dut._log.info("Initial burst: %d/%d passed", passed, burst)
    assert passed == burst, f"Expected all {burst} burst packets to pass, got {passed}"


@cocotb.test()
async def test_rate_drop_after_burst(dut):
    """Packet after burst exhaustion should be dropped by rate limiter."""
    await setup(dut)

    burst = int(dut.BURST.value)

    # Exhaust all tokens
    for _ in range(burst):
        await send_packet(dut, pass_in=1)

    # Next packet should be rate-dropped
    result = await send_packet(dut, pass_in=1)
    dut._log.info("After burst exhaustion: pass_out=%d (expected 0)", result)
    assert result == 0, "Expected rate drop after burst exhaustion"


@cocotb.test()
async def test_token_refill(dut):
    """After waiting refill interval, one more token should be available."""
    await setup(dut)

    burst = int(dut.BURST.value)
    pps = int(dut.PPS.value)

    # Exhaust all tokens
    for _ in range(burst):
        await send_packet(dut, pass_in=1)

    # Wait for at least one refill cycle (clock_freq / PPS cycles)
    # At 100 MHz with PPS=1000: refill_interval = 100000 cycles
    refill_cycles = 100_000_000 // max(pps, 1)  # Approximate for 100 MHz
    await ClockCycles(dut.clk, refill_cycles + 100)

    # Now should have at least 1 token
    result = await send_packet(dut, pass_in=1)
    dut._log.info("After refill wait: pass_out=%d (expected 1)", result)
    assert result == 1, "Expected token refill to allow packet"


@cocotb.test()
async def test_upstream_drop_passthrough(dut):
    """If pass_in=0 (upstream rule dropped), pass_out should also be 0."""
    await setup(dut)

    result = await send_packet(dut, pass_in=0)
    dut._log.info("Upstream drop: pass_out=%d (expected 0)", result)
    assert result == 0, "Expected pass_out=0 when pass_in=0"


@cocotb.test()
async def test_token_cap(dut):
    """Tokens should never exceed BURST even after long idle."""
    await setup(dut)

    burst = int(dut.BURST.value)

    # Wait a very long time to accumulate tokens
    await ClockCycles(dut.clk, 1_000_000)

    # Send burst+1 packets
    passed = 0
    for _ in range(burst + 1):
        result = await send_packet(dut, pass_in=1)
        if result == 1:
            passed += 1

    dut._log.info("Token cap: %d/%d passed (burst=%d)", passed, burst + 1, burst)
    assert passed == burst, f"Tokens should cap at BURST={burst}, got {passed}"
