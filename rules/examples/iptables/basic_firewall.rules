-A INPUT -p icmp --icmp-type echo-request -j ACCEPT
-A INPUT -p tcp --dport 22 -m comment --comment "Allow SSH" -j ACCEPT
-A INPUT -p tcp -m multiport --dports 80,443 -m comment --comment "Allow HTTP/HTTPS" -j ACCEPT
